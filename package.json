{
  "name": "openbuddy",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "description": "OpenBuddy — a WorkBuddy-style desktop shell for the grok agent, built on Tauri.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dist": "node -e \"process.platform==='win32'?require('child_process').execFileSync('powershell',['-ExecutionPolicy','Bypass','-File','scripts/build.ps1'],{stdio:'inherit'}):require('child_process').execFileSync('bash',['scripts/build.sh'],{stdio:'inherit'})\"",
    "dist:win": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1",
    "dist:mac": "bash scripts/build.sh",
    "setup:win": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "setup:mac": "bash scripts/setup.sh",
    "test": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "katex": "^0.18.1",
    "linkify-it": "^6.0.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.460.0",
    "mermaid": "^11.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.28.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.1.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/hast": "^3.0.5",
    "@types/linkify-it": "^5.0.0",
    "@types/mdast": "^4.0.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9",
    "ws": "^8.21.1"
  }
}
